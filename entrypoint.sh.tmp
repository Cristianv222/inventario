#!/bin/bash
set -e

echo "Esperando a que la base de datos esté lista..."
while ! pg_isready -h db -p 5432 -U ${DB_USER} -d ${DB_NAME}; do
    echo "Esperando a PostgreSQL..."
    sleep 2
done
echo "Base de datos lista!"

